{
  "manifest_version": 3,
  "name": "Autofill Graph - Privacy-First Knowledge Assistant",
  "version": "2.0.0",
  "description": "Temporal knowledge graph autofill with privacy-aware multi-layer architecture and intelligent inference",
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Autofill Graph Assistant"
  },
  "web_accessible_resources": [
    {
      "resources": ["popup/inject.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
